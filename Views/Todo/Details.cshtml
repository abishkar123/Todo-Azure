@model TodoApp.Models.TodoItem
@{
    ViewData["Title"] = "Task Details";
    var priorityBadge = Model.Priority switch
    {
        Priority.Urgent => "bg-danger",
        Priority.High => "bg-warning text-dark",
        Priority.Medium => "bg-info",
        _ => "bg-secondary"
    };
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="detail-card">
                <div class="detail-card-header">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <h2 class="@(Model.IsDone ? "text-decoration-line-through text-muted" : "")">
                                @if (Model.IsImportant)
                                {
                                    <i class="bi bi-star-fill text-warning me-2"></i>
                                }
                                @Model.Title
                            </h2>
                            <div class="detail-badges mt-2">
                                @if (Model.IsDone)
                                {
                                    <span class="badge bg-success me-2"><i class="bi bi-check-circle me-1"></i>Completed</span>
                                }
                                else
                                {
                                    <span class="badge bg-primary me-2"><i class="bi bi-hourglass-split me-1"></i>Pending</span>
                                }
                                <span class="badge @priorityBadge me-2"><i class="bi bi-flag me-1"></i>@Model.Priority Priority</span>
                                @if (!string.IsNullOrEmpty(Model.Category))
                                {
                                    <span class="badge bg-dark"><i class="bi bi-tag me-1"></i>@Model.Category</span>
                                }
                            </div>
                        </div>
                        <div class="detail-actions">
                            <a href="/Todo/Edit/@Model.Id" class="btn btn-outline-primary">
                                <i class="bi bi-pencil me-1"></i>Edit
                            </a>
                        </div>
                    </div>
                </div>
                <div class="detail-card-body">
                    @if (!string.IsNullOrEmpty(Model.Description))
                    {
                        <div class="detail-section">
                            <h6 class="detail-label"><i class="bi bi-card-text me-2"></i>Description</h6>
                            <p class="detail-text">@Model.Description</p>
                        </div>
                    }
                    
                    <div class="row g-4">
                        @if (Model.DueDate.HasValue)
                        {
                            <div class="col-md-6">
                                <div class="detail-info-card @(Model.IsOverdue ? "overdue" : "")">
                                    <i class="bi bi-calendar3"></i>
                                    <div>
                                        <span class="detail-info-label">Due Date</span>
                                        <span class="detail-info-value">
                                            @Model.DueDate.Value.ToString("MMMM dd, yyyy")
                                            @if (Model.IsOverdue)
                                            {
                                                <span class="text-danger fw-bold"> (Overdue!)</span>
                                            }
                                            else if (Model.IsDueToday)
                                            {
                                                <span class="text-warning fw-bold"> (Today)</span>
                                            }
                                        </span>
                                    </div>
                                </div>
                            </div>
                        }
                        <div class="col-md-6">
                            <div class="detail-info-card">
                                <i class="bi bi-clock-history"></i>
                                <div>
                                    <span class="detail-info-label">Created</span>
                                    <span class="detail-info-value">@Model.CreatedAt.ToLocalTime().ToString("MMMM dd, yyyy 'at' h:mm tt")</span>
                                </div>
                            </div>
                        </div>
                        @if (Model.CompletedAt.HasValue)
                        {
                            <div class="col-md-6">
                                <div class="detail-info-card completed">
                                    <i class="bi bi-check-circle"></i>
                                    <div>
                                        <span class="detail-info-label">Completed</span>
                                        <span class="detail-info-value">@Model.CompletedAt.Value.ToLocalTime().ToString("MMMM dd, yyyy 'at' h:mm tt")</span>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
                <div class="detail-card-footer">
                    <a href="/" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-2"></i>Back to Dashboard
                    </a>
                    <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this task?');">
                        <button type="submit" class="btn btn-outline-danger">
                            <i class="bi bi-trash me-2"></i>Delete Task
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
